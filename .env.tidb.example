# TiDB Cloud Configuration
# Get these from: https://tidbcloud.com/console/clusters

# Option 1: Connection String (Recommended - from TiDB Cloud dashboard)
TIDB_DATABASE_URL=mysql://<user>:<password>@<host>:4000/<database>?sslaccept=strict

# Option 2: Individual variables
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=<your-user>
TIDB_PASSWORD=<your-password>
TIDB_DATABASE=taskflow

# Alternative: Generic DATABASE_URL (works with any MySQL-compatible DB)
# DATABASE_URL=mysql://...
