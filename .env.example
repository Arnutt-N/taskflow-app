# TiDB Cloud Connection (choose one method)

# Method 1: Connection String (recommended)
DATABASE_URL="mysql://xxxxxxxx.root:xxxxxxxx@xxx.xxx.tidbcloud.com:4000/taskflow?sslaccept=strict"

# Method 2: Individual Variables
# TIDB_HOST=xxx.xxx.tidbcloud.com
# TIDB_PORT=4000
# TIDB_USER=xxxxxxxx.root
# TIDB_PASSWORD=xxxxxxxx
# TIDB_DATABASE=taskflow

# For local development (uses file system, no database needed)
# Leave all database variables empty to use JSON files in /data folder

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here
